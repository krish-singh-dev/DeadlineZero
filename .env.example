# DeadlineZero Production Environment Variables Reference (.env.example)
# Cites Rule 24 (Zero-Trust Security & Secrets Management)

# 1. Google Cloud Run Container Server
PORT=8080
NODE_ENV=production

# 2. Firebase Client & Admin Credentials (User Data Isolation)
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy_demo_client_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="deadlinezero.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="deadlinezero-prod"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="deadlinezero-prod.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
NEXT_PUBLIC_FIREBASE_APP_ID="1:1234567890:web:abcdef123456"

# Server-Side Firebase Admin Service Account JSON Base64 (or ADC inside Cloud Run)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"deadlinezero-prod"}'

# 3. Google DeepMind Gemini AI Core
GEMINI_API_KEY="AIzaSy_demo_gemini_api_key_15_pro_flash"

# 4. Google Calendar REST API Sync
GOOGLE_CALENDAR_CLIENT_ID="123456.apps.googleusercontent.com"
GOOGLE_CALENDAR_CLIENT_SECRET="GOCSPX-demo_secret"
